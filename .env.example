# --- Required ---
# Gemini API key. Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Optional (sensible defaults shown) ---
# Gemini model. Recommended free-tier model is gemini-2.0-flash.
GEMINI_MODEL=gemini-2.0-flash

# SQLite database location.
DATABASE_URL=sqlite:///./founderhunt.db

# Per-user daily search quota. Disabled by default (see SPEC 4.6 "as built").
QUOTA_ENABLED=false
DAILY_QUOTA=10

# Human-in-the-loop checkpoint: seconds the worker waits for a human to clear a wall.
CHECKPOINT_TIMEOUT_SECONDS=60

# Max normalized jobs stored per search.
MAX_RESULTS_PER_SEARCH=10

# Run Chromium visibly. Must be false-ish only if you do not need the human checkpoint.
PLAYWRIGHT_HEADLESS=false

# Run the two sources at the same time (true) or one after the other (false).
SOURCES_CONCURRENT=true

# Where persisted Playwright browser sessions are stored (stretch goal S4).
PLAYWRIGHT_STATE_DIR=playwright-state
